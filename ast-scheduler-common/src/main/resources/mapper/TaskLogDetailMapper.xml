<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ast.scheduler.common.mapper.TaskLogDetailMapper">

    <resultMap id="BaseResultMap" type="com.ast.scheduler.common.entity.TaskLogDetail">
        <id column="id" property="id"/>
        <result column="log_id" property="logId"/>
        <result column="full_output" property="fullOutput"/>
        <result column="full_log" property="fullLog"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByLogId" resultMap="BaseResultMap">
        SELECT * FROM t_task_log_detail WHERE log_id = #{logId}
    </select>

    <insert id="insert" parameterType="com.ast.scheduler.common.entity.TaskLogDetail" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_task_log_detail (log_id, full_output, full_log)
        VALUES (#{logId}, #{fullOutput}, #{fullLog})
    </insert>

    <delete id="deleteByLogId">
        DELETE FROM t_task_log_detail WHERE log_id = #{logId}
    </delete>

</mapper>
